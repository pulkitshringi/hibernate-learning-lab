# Build output (Maven and Gradle)
**/target/
**/build/
**/out/
**/.gradle/

# Compiled and packaged Java artifacts
*.class
*.jar
*.war
*.ear
*.nar

# Keep build-tool wrapper binaries
!**/.mvn/wrapper/maven-wrapper.jar
!**/gradle/wrapper/gradle-wrapper.jar

# IntelliJ IDEA
**/.idea/
*.iml
*.iws
*.ipr

# Eclipse and Spring Tool Suite
**/.classpath
**/.project
**/.settings/
**/.factorypath
**/.apt_generated/
**/.springBeans
**/.sts4-cache/

# Visual Studio Code and NetBeans
**/.vscode/
**/nbproject/private/
**/nbbuild/
**/dist/
**/nbdist/
**/.nb-gradle/

# Logs, crash reports, and temporary files
*.log
hs_err_pid*
replay_pid*
*.tmp
*.swp
*~

# Local databases commonly used while learning Hibernate
*.db
*.sqlite
*.sqlite3
*.mv.db
*.trace.db

# Local environment and secrets
.env
.env.*
!.env.example

# Operating-system metadata
.DS_Store
Thumbs.db
